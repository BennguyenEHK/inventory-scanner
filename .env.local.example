# ─── Gemini (PRIMARY for vision — Gemini 2.5 Flash) ─────────────────────────────────────
GEMINI_KEYS=your-gemini-api-key

# ─── HuggingFace Inference Providers (FALLBACK for vision, PRIMARY for reasoning) ───────
HF_TOKEN=hf_...
HF_BASE_URL=https://router.huggingface.co/v1/chat/completions

# ─── RunPod persistent pods (OPTIONAL FALLBACK) ─────────────────────────────────────────
# URL format: https://<pod-id>-<port>.proxy.runpod.net/v1
RUNPOD_VISION_URL=https://your-vision-pod-id-8000.proxy.runpod.net/v1
RUNPOD_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
RUNPOD_REASONING_URL=https://your-reasoning-pod-id-8000.proxy.runpod.net/v1
RUNPOD_REASONING_MODEL=Qwen/Qwen3.6-35B-A3B
RUNPOD_API_KEY=                  # optional — leave blank for pod proxy URLs
RUNPOD_TIMEOUT_MS=90000

# ─── Notion ──────────────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=

# ─── Search + Scrape ──────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...
