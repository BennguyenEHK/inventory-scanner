# RunPod persistent pod — OpenAI-compatible vLLM server
# URL format: https://<pod-id>-<port>.proxy.runpod.net/v1
RUNPOD_BASE_URL=https://your-pod-id-8000.proxy.runpod.net/v1
RUNPOD_MODEL=inventScan
RUNPOD_API_KEY=                  # optional — leave blank for pod proxy URLs
RUNPOD_TIMEOUT_MS=90000

# HuggingFace Inference Providers (fallback)
HF_TOKEN=hf_...
HF_BASE_URL=https://router.huggingface.co/v1/chat/completions

# Notion
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=

# Search + Scrape
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...
